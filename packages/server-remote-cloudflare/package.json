{
	"name": "@epicenter/server-remote-cloudflare",
	"version": "0.0.1",
	"type": "module",
	"main": "./src/app.ts",
	"types": "./src/app.ts",
	"license": "AGPL-3.0",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"dev:local": "wrangler dev",
		"dev:remote": "infisical run --watch --path=/api -- wrangler dev",
		"deploy": "wrangler deploy",
		"typegen": "wrangler types",
		"auth:generate": "bun x @better-auth/cli generate --yes --config ./better-auth.config.ts --output ./src/db/schema.ts",
		"db:generate": "drizzle-kit generate",
		"db:drop": "drizzle-kit drop",
		"db:push:local": "drizzle-kit push",
		"db:push:remote": "infisical run --path=/api -- drizzle-kit push",
		"db:migrate:local": "drizzle-kit migrate",
		"db:migrate:remote": "infisical run --path=/api -- drizzle-kit migrate",
		"db:studio:local": "drizzle-kit studio",
		"db:studio:remote": "infisical run --path=/api -- drizzle-kit studio"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "catalog:",
		"@better-auth/oauth-provider": "catalog:",
		"@epicenter/sync": "workspace:*",
		"lib0": "catalog:",
		"y-protocols": "catalog:",
		"@hono/standard-validator": "^0.2.2",
		"@tanstack/ai": "^0.5.1",
		"@tanstack/ai-anthropic": "^0.5.0",
		"@tanstack/ai-openai": "^0.5.0",
		"@types/bun": "^1.3.10",
		"arktype": "catalog:",
		"better-auth": "catalog:",
		"drizzle-orm": "catalog:",
		"hono": "catalog:",
		"hono-openapi": "^1.3.0",
		"postgres": "^3.4.8",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"dotenv": "^17.3.1",
		"drizzle-kit": "catalog:",
		"jsonc-parser": "^3.3.1",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}

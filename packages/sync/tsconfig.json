{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "Preserve",
		"allowJs": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"sourceMap": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noPropertyAccessFromIndexSignature": false
	}
}

{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "self-host",
	"main": "worker/index.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat", "enable_request_signal"],
	"send_metrics": false,

	// --- Deployment-owned vars ---
	// ALLOWED_MEMBER_EMAILS: comma-separated list of emails admitted by the
	// shared() ownership rule. Anyone outside this set gets 403 NotAdmitted
	// at the boundary, regardless of whether they can sign in.
	"vars": {
		// API_PUBLIC_ORIGIN: this deployment's public origin. Self-hosters set
		// their own domain here; it is the Better Auth issuer + token audience.
		"API_PUBLIC_ORIGIN": "https://self-host.example.com",
		"ALLOWED_MEMBER_EMAILS": ""
	},

	// --- Deployment-owned secrets ---
	// Set via `wrangler secret put`. ENCRYPTION_SECRETS controls the trust
	// boundary: it lives only in this deployment's environment, so Epicenter
	// cannot decrypt anything stored here. Self-hosted = functionally
	// zero-knowledge against Epicenter.
	//
	// AI provider house keys (OPENAI_API_KEY, GEMINI_API_KEY) are optional:
	// `wrangler secret put` one to serve that provider to all members, or
	// omit it and members bring their own key per request (BYOK). A house-key
	// request for a missing key gets 503 ProviderNotConfigured.
	"secrets": {
		"required": [
			"BETTER_AUTH_SECRET",
			"ENCRYPTION_SECRETS",
			// GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET are an environment-specific
			// OAuth pair: set both via `wrangler secret put` for your own Google
			// client. Filed as secrets (not vars) so dev reads them from the
			// environment like every other credential.
			"GOOGLE_CLIENT_ID",
			"GOOGLE_CLIENT_SECRET"
		]
	},

	// --- KV: Session cache (Better Auth SecondaryStorage) ---
	// Create with: bunx wrangler kv namespace create "<your-namespace>"
	"kv_namespaces": [
		{
			"binding": "SESSION_KV",
			"id": "<your-kv-namespace-id>"
		}
	],

	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "ROOM",
				"class_name": "Room"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["Room"]
		}
	],

	// --- Hyperdrive: Postgres connection pool ---
	// Create with: bunx wrangler hyperdrive create <name> --connection-string="postgres://..."
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "<your-hyperdrive-id>",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/self_host"
		}
	],

	// --- R2: Asset storage ---
	"r2_buckets": [
		{
			"binding": "ASSETS_BUCKET",
			"bucket_name": "<your-r2-bucket>"
		}
	]
}

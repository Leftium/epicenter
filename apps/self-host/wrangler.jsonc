{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "self-host",
	"main": "worker/index.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat", "enable_request_signal"],
	"send_metrics": false,

	// --- Deployment-owned vars ---
	// ALLOWED_MEMBER_EMAILS: comma-separated list of emails admitted by the
	// shared() ownership rule. Anyone outside this set gets 403 NotAdmitted
	// at the boundary, regardless of whether they can sign in.
	"vars": {
		// API_PUBLIC_ORIGIN: this deployment's public origin. Self-hosters set
		// their own domain here; it is the Better Auth issuer + token audience.
		"API_PUBLIC_ORIGIN": "https://self-host.example.com",
		"ALLOWED_MEMBER_EMAILS": "",
		"GOOGLE_CLIENT_ID": ""
	},

	// --- Deployment-owned secrets ---
	// Set via `wrangler secret put`. Self-hosting is the trust boundary: this
	// deployment runs on infrastructure you operate, so Epicenter never holds or
	// sees the data stored here. Self-hosted = functionally zero-knowledge
	// against Epicenter.
	//
	// AI provider house keys (OPENAI_API_KEY, GEMINI_API_KEY) are optional:
	// `wrangler secret put` one to serve that provider to all members through
	// this gateway, or omit it and that provider returns 503
	// ProviderNotConfigured. The gateway is house-key-only (ADR-0054): members
	// who want their own key point their client at a custom backend instead.
	"secrets": {
		"required": ["BETTER_AUTH_SECRET", "GOOGLE_CLIENT_SECRET"]
	},

	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "ROOM",
				"class_name": "Room"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["Room"]
		}
	],

	// --- Hyperdrive: Postgres connection pool ---
	// Create with: bunx wrangler hyperdrive create <name> --connection-string="postgres://..."
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "<your-hyperdrive-id>",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/self_host"
		}
	]
}

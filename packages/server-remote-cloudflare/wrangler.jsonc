{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "epicenter-remote",
	"main": "src/app.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat"],
	"send_metrics": false,

	// --- KV: Session cache (Better Auth SecondaryStorage) ---
	"kv_namespaces": [
		{
			"binding": "SESSION_KV",
			"id": "local-dev-placeholder"
		}
	],

	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "YJS_ROOM",
				"class_name": "YjsRoom"
			}
		]
	},

	// SQLite-backed DO — persistent storage survives hibernation.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["YjsRoom"]
		}
	],

	// --- Secrets (set via `wrangler secret put`, typed via `wrangler types`) ---
	"secrets": {
		"required": [
			"BETTER_AUTH_SECRET",
			"OPENAI_API_KEY",
			"ANTHROPIC_API_KEY",
			"GEMINI_API_KEY",
			"GROK_API_KEY"
		]
	},

	// --- Hyperdrive: Postgres connection pool ---
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "<created-via-wrangler-cli>",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/epicenter"
		}
	]
}

# apps/api Bun entry (server.ts) — the Bun/self-host runtime port.
#
# `bun run dev:bun` runs the same server as `wrangler dev` against plain
# Postgres + S3, no Cloudflare account. Bun auto-loads this file when copied to
# `.env`. (The `dev` script, which runs `wrangler dev`, ignores this file and
# reads secrets from Infisical instead.)

# Required: Postgres connection string (any Postgres: local Docker, Neon, ...).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/epicenter

# Required: Better Auth signing secret (any high-entropy string).
BETTER_AUTH_SECRET=replace-me

# Google OAuth (the only sign-in provider; email/password is disabled).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional GitHub OAuth (omit both to stay Google-only).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Listen port and public origin. The origin must match where the process is
# actually reachable: it becomes the auth baseURL, OAuth issuer, and token
# audience. Defaults to http://localhost:<PORT> (8788, off wrangler's 8787).
PORT=8788
# API_PUBLIC_ORIGIN=http://localhost:8788

# Room update logs: one bun:sqlite file per room under this directory. Keep it
# on a local disk (WAL does not work on networked filesystems).
DATA_DIR=./.data/rooms

# Object storage for content-addressed blobs. Point at R2 or a local MinIO /
# Garage. Omit to run without blobs (the blob routes answer 503).
# BLOBS_S3_ENDPOINT=http://localhost:9000
# BLOBS_S3_ACCESS_KEY_ID=
# BLOBS_S3_SECRET_ACCESS_KEY=
# BLOBS_S3_BUCKET=epicenter-blobs
# BLOBS_S3_REGION=auto

# AI gateway house keys (optional; a request for a provider 503s without its key).
# OPENAI_API_KEY=
# GEMINI_API_KEY=

{
	"extends": ["../../tsconfig.base.json"],
	"compilerOptions": {
		"allowJs": true,
		"resolveJsonModule": true,

		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
		"sourceMap": true,

		"declaration": true,
		"composite": true,
		"declarationMap": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}

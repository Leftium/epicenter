# local-books scheduled-sync environment.
# Copy to ~/.config/local-books/env and `chmod 600`.
#
# These are your Intuit app CLIENT credentials, needed to refresh an expired
# access token during an unattended sync. The OAuth tokens themselves are NOT
# here: they live in your OS keyring after `local-books auth`.

QB_CLIENT_ID=your-production-client-id
QB_CLIENT_SECRET=your-production-client-secret

# Mirror your real company (default is the sandbox).
LOCAL_BOOKS_QB_ENV=production

# Optional overrides:
# LOCAL_BOOKS_DIR=/home/you/.local/share/local-books
# Headless box with no keyring daemon: use a 0600 file token store instead.
# LOCAL_BOOKS_KEYRING_FILE=/home/you/.config/local-books/keyring.json

{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "epicenter-remote",
	"main": "src/app.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat"],
	"send_metrics": false,

	// --- Custom domain: api.epicenter.so ---
	"routes": [
		{ "pattern": "api.epicenter.so/*", "zone_name": "epicenter.so" }
	],

	// --- Vars: non-secret config accessible via env ---
	"vars": {
		"BASE_URL": "https://api.epicenter.so"
	},

	// --- KV: Session cache (Better Auth SecondaryStorage) ---
	// Create with: bunx wrangler kv namespace create "epicenter-sessions"
	"kv_namespaces": [
		{
			"binding": "SESSION_KV",
			"id": "<run: bunx wrangler kv namespace create epicenter-sessions>"
		}
	],

	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "YJS_ROOM",
				"class_name": "YjsRoom"
			}
		]
	},

	// SQLite-backed DO — persistent storage survives hibernation.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["YjsRoom"]
		}
	],

	// --- Secrets (set via `wrangler secret put`, typed via `wrangler types`) ---
	"secrets": {
		"required": [
			"BETTER_AUTH_SECRET",
			"OPENAI_API_KEY",
			"ANTHROPIC_API_KEY"
			// "GEMINI_API_KEY",
			// "GROK_API_KEY"
		]
	},

	// --- Hyperdrive: Postgres connection pool ---
	// Create with: bunx wrangler hyperdrive create epicenter-db --connection-string="postgres://..."
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "<run: bunx wrangler hyperdrive create epicenter-db>",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/epicenter"
		}
	]
}

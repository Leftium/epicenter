{
	// https://biomejs.dev/internals/language-support/
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[svelte]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[astro]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"[html]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "always"
	},
	"[markdown]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	// Repair relative Markdown links when a note is renamed or moved in the Explorer.
	// Same convention as javascript/typescript updateImportsOnFileMove; see
	// docs/articles/20260607T143000-markdown-link-repair-is-the-only-irreversible-choice.md
	"markdown.updateLinksOnFileMove.enabled": "always"
}

{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"paths": {
			"#hooks": ["./src/hooks/index.ts"],
			"#hooks/*.svelte.js": ["./src/hooks/*.svelte.ts"],
			"#ui": ["./src"],
			"#ui/*": ["./src/*"],
			"#ui/*/index.js": ["./src/*/index.ts"],
			"#utils": ["./src/utils.ts"],
			"#utils.js": ["./src/utils.ts"],
			"#utils/*.js": ["./src/utils/*.ts"]
		}
	}
}

# Epicenter Hub — Standalone Server
# Copy this file to .env and fill in your values.

# Server port (default: 3913)
# PORT=3913

# Auth mode: leave empty for no auth, or set AUTH_TOKEN for pre-shared secret
# AUTH_TOKEN=your-secret-token

# For betterAuth mode (full auth with database):
# DATABASE_URL=postgres://user:pass@localhost:5432/epicenter
# BETTER_AUTH_SECRET=your-secret-key
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-admin-password

# AI provider API keys (optional — enables /ai/chat and /proxy routes)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

{
	"name": "@epicenter/server-remote-cloudflare",
	"version": "0.0.1",
	"type": "module",
	"main": "./src/app.ts",
	"types": "./src/app.ts",
	"license": "AGPL-3.0",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"typegen": "wrangler types",
		"auth:generate": "bun x @better-auth/cli generate --yes --config ./better-auth.config.ts --output ./src/db/schema.ts",
		"db:push": "drizzle-kit push --config drizzle.config.ts",
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config drizzle.config.ts"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "catalog:",
		"@better-auth/oauth-provider": "catalog:",
		"@epicenter/sync-core": "workspace:*",
		"@tanstack/ai": "^0.5.1",
		"@tanstack/ai-anthropic": "^0.5.0",
		"@tanstack/ai-gemini": "^0.5.0",
		"@tanstack/ai-grok": "^0.5.0",
		"@tanstack/ai-openai": "^0.5.0",
		"@types/bun": "^1.3.10",
		"better-auth": "catalog:",
		"drizzle-orm": "catalog:",
		"hono": "catalog:",
		"postgres": "^3.4.8",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"dotenv": "^17.3.1",
		"drizzle-kit": "catalog:",
		"jsonc-parser": "^3.3.1",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}

{
	"extends": ["../../tsconfig.base.dom.json"],
	"compilerOptions": {
		"allowJs": true,
		"resolveJsonModule": true,

		"outDir": "dist",
		"sourceMap": true,

		"declaration": true,
		"composite": true,
		"declarationMap": true,

		"rootDir": "src",
		"paths": {
			"#/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}

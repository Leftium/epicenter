{
	"fields": {
		"title": { "type": "string" },
		"status": { "type": "string", "enum": ["draft", "ready", "published", "archived"] },
		"format": { "type": "string", "enum": ["article", "carousel", "video"] },
		"destinations": {
			"anyOf": [{ "type": "array", "items": { "type": "string" } }, { "type": "null" }]
		},
		"publishDate": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
		"duration": { "anyOf": [{ "type": "integer" }, { "type": "null" }] },
		"url": { "anyOf": [{ "type": "string", "format": "uri" }, { "type": "null" }] }
	}
}

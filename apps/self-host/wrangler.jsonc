{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "self-host",
	"main": "worker/index.ts",
	"compatibility_date": "2026-03-06",
	"compatibility_flags": ["nodejs_compat", "enable_request_signal"],
	"send_metrics": false,

	// --- Deployment-owned vars ---
	"vars": {
		// API_PUBLIC_ORIGIN: this instance's public origin. Self-hosters set
		// their own domain here; it is the token audience and Better Auth baseURL.
		"API_PUBLIC_ORIGIN": "https://instance.example.com"
	},

	// --- Deployment-owned secrets ---
	// Set via `wrangler secret put`. Self-hosting is the trust boundary: this
	// instance runs on infrastructure you operate, so Epicenter never holds or
	// sees the data stored here. Self-hosted = functionally zero-knowledge
	// against Epicenter.
	//
	// INSTANCE_TOKEN: the one operator-supplied bearer that authenticates every
	// request (ADR-0073). Generate it with `bun run gen-token` and set it with
	// `wrangler secret put INSTANCE_TOKEN`; hand the same value to whoever should
	// have access and paste it into their client instance setting. There is no
	// OAuth and no allowlist: "solo" vs "shared" is only how many people hold it.
	//
	// BETTER_AUTH_SECRET: still required. `createServerApp` constructs Better Auth
	// (the session route reads it) even though the instance authenticates by bearer
	// and issues no sessions; set any random value (`openssl rand -base64 32`).
	//
	// AI provider house keys (OPENAI_API_KEY, GEMINI_API_KEY) are optional:
	// `wrangler secret put` one to serve that provider through this gateway, or
	// omit it and that provider returns 503 ProviderNotConfigured. House-key-only
	// (ADR-0054): a member who wants their own key points their client at a custom
	// backend instead.
	"secrets": {
		"required": ["INSTANCE_TOKEN", "BETTER_AUTH_SECRET"]
	},

	// --- Durable Objects ---
	"durable_objects": {
		"bindings": [
			{
				"name": "ROOM",
				"class_name": "Room"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["Room"]
		}
	],

	// --- Hyperdrive: Postgres connection pool ---
	// Create with: bunx wrangler hyperdrive create <name> --connection-string="postgres://..."
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "<your-hyperdrive-id>",
			"localConnectionString": "postgres://postgres:postgres@localhost:5432/self_host"
		}
	]
}

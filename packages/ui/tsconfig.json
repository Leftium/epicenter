{
	"extends": ["../../tsconfig.base.lib.json"],
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"outDir": "dist",
		"composite": true,
		"rootDir": "src",
		"paths": {
			"#/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
